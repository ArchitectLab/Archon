# Archon : regles d'ignore
# La stack se precise (voir docs/ARCHITECTURE.md). Ce fichier couvre les cas courants
# (OS, editeurs, .NET, Node, Python) et la base locale.

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editeurs / IDE
.vs/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# Claude Code (on versionne les skills, pas les reglages locaux)
.claude/settings.local.json
.claude/*.local.json

# Secrets / environnement
.env
.env.*
!.env.example
*.pem
*.key

# Archon : base de donnees locale (SQLite)
archon.db
*.db-shm
*.db-wal

# .NET
bin/
obj/
*.user

# Node
node_modules/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*
dist/
build/
# La surface React (src/Archon.Surface) : on ignore ses dependances, mais on VERSIONNE son
# build (src/Archon.Web/wwwroot/app) pour lancer Archon sans Node. Voir docs/dev-quickstart.md.
src/Archon.Surface/node_modules/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.pytest_cache/

# Logs / divers
*.log
coverage/
