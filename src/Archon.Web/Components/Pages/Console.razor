@page "/console"
@rendermode InteractiveServer
@implements IDisposable
@inject IOrchestrator Orchestrator
@inject PluginRegistry Registry
@inject IAuditLog Audit
@inject ILanguageModel Brain
@inject ApprovalQueue Approvals
@inject ApprovalSettings Settings

<PageTitle>Archon - Console</PageTitle>

<section class="al-console">
    <div class="al-console__main">
        <p class="al-eyebrow">// CONSOLE D'ORCHESTRATION</p>
        <h1 class="al-display">Pilote<span class="al-cursor">_</span></h1>

        <div class="al-mode">
            <span class="al-mode__label">Approbation des actions :</span>
            <div class="al-seg">
                <button class="al-seg__btn @(Settings.Mode == ApprovalMode.Ask ? "is-on" : "")"
                        @onclick="() => SetMode(ApprovalMode.Ask)">Demander mon accord</button>
                <button class="al-seg__btn @(Settings.Mode == ApprovalMode.AutoRun ? "is-on" : "")"
                        @onclick="() => SetMode(ApprovalMode.AutoRun)">Laisser l'IA agir</button>
            </div>
        </div>

        <div class="al-cmd">
            <span class="al-cmd__prompt">&gt;</span>
            <input class="al-cmd__input" @bind="_input" @bind:event="oninput" @onkeydown="OnKey"
                   placeholder="ex : allume la lumiere du salon" />
            <button class="al-btn al-btn--spectrum al-btn--sm" @onclick="Send" disabled="@_busy">Envoyer</button>
        </div>

        <p class="al-meta">
            Cerveau : <span class="al-mono">@Brain.Name</span>@(Brain.IsConfigured ? "" : " (repli mots-cles)")
        </p>

        @foreach (var pa in Approvals.Pending())
        {
            <article class="al-card al-card--accent al-approval">
                <p class="al-eyebrow">APPROBATION REQUISE</p>
                <p class="al-approval__detail">@pa.Detail</p>
                <div class="al-actions">
                    <button class="al-btn al-btn--spectrum al-btn--sm" @onclick="() => Approvals.Resolve(pa.Id, true)">Approuver</button>
                    <button class="al-btn al-btn--secondary al-btn--sm" @onclick="() => Approvals.Resolve(pa.Id, false)">Refuser</button>
                </div>
            </article>
        }

        @if (_busy)
        {
            <p class="al-meta">L'orchestrateur reflechit...</p>
        }
        else if (!string.IsNullOrEmpty(_message))
        {
            <p class="al-msg @(_success ? "al-msg--ok" : "al-msg--err")">@_message</p>
        }

        @if (_ui is not null)
        {
            <article class="al-card al-card--accent">
                <UiRenderer View="_ui" />
            </article>
        }
    </div>

    <aside class="al-console__side">
        <p class="al-eyebrow">// REGISTRE</p>
        <ul class="al-registry">
            @foreach (var r in Registry.All())
            {
                <li class="al-reg">
                    <span class="al-dot @(r.Health == PluginHealth.Online ? "al-dot--on" : "al-dot--off")"></span>
                    <span class="al-reg__name">@r.Plugin.Manifest.Name</span>
                    <span class="al-tag">v@(r.Plugin.Manifest.Version)</span>
                    <span class="al-reg__status">@(r.Health == PluginHealth.Online ? "online" : "offline")</span>
                </li>
            }
        </ul>

        <p class="al-eyebrow">// JOURNAL</p>
        <ul class="al-audit">
            @foreach (var ev in Audit.Recent(10))
            {
                <li class="@(ev.Allowed ? "" : "al-audit--deny")">
                    <span class="al-mono">@ev.Action</span> @ev.Detail
                </li>
            }
            @if (Audit.Recent(1).Count == 0)
            {
                <li class="al-muted">Aucune action pour l'instant.</li>
            }
        </ul>
    </aside>
</section>

@code {
    private string _input = "";
    private bool _busy;
    private bool _success;
    private string? _message;
    private UiView? _ui;

    protected override void OnInitialized() => Approvals.Changed += OnApprovalsChanged;

    private void OnApprovalsChanged() => InvokeAsync(StateHasChanged);

    private void SetMode(ApprovalMode mode)
    {
        Settings.Mode = mode;
        StateHasChanged();
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(_input) || _busy)
        {
            return;
        }

        _busy = true;
        _message = null;
        _ui = null;

        var resp = await Orchestrator.HandleAsync(_input);
        _success = resp.Success;
        _message = resp.Message;
        _ui = resp.Ui;
        _busy = false;
    }

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Send();
        }
    }

    public void Dispose() => Approvals.Changed -= OnApprovalsChanged;
}
